<Window x:Class="VolumeMixerPro.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Volume Overlay" Height="120" Width="300"
        WindowStyle="None" AllowsTransparency="True" Background="{x:Null}"
        ResizeMode="NoResize" Topmost="True" ShowInTaskbar="False"
        WindowStartupLocation="Manual" Left="-5000" Top="-5000" Opacity="0"
        Visibility="Hidden">
    
    <Border Name="MainBorder" Background="#F20F1419" BorderBrush="#44FFFFFF" BorderThickness="1.5" CornerRadius="4">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Name="AppNameText" Foreground="White" FontSize="12" FontWeight="SemiBold" 
                       HorizontalAlignment="Center" Margin="0,8,0,4"/>
            <TextBlock Name="VolumeText" Foreground="White" FontSize="22" FontWeight="Bold"
                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
            <TextBlock Name="AsciiBar" Foreground="#00ADEF" FontSize="14" FontFamily="Consolas"
                       HorizontalAlignment="Center" Margin="0,0,0,10"/>
        </StackPanel>
    </Border>
</Window>
