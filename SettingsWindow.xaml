<Window x:Class="VolumeMixerPro.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Height="500" Width="700"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        UseLayoutRounding="True" SnapsToDevicePixels="True"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Topmost="True">
    <Border BorderThickness="0" CornerRadius="12">
        <Border.Background>
            <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                <GradientStop Color="#FF1C2128" Offset="0"/>
                <GradientStop Color="#FF0F1419" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="50"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Background="#1C2128" CornerRadius="12,12,0,0" MouseLeftButtonDown="Header_MouseLeftButtonDown">
                <Grid>
                    <Button Content="❓" HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="15,0,0,0" Width="30" Height="30"
                            Style="{StaticResource ActionButtonStyle}" Click="HelpButton_Click" ToolTip="Help"/>
                    <TextBlock Text="⚙️  Utility Setting" Foreground="White" 
                               FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Center"
                            Margin="0,0,15,0" Width="30" Height="30"
                            Foreground="#FF6B6B" Background="Transparent" BorderThickness="0"
                            FontSize="16" FontWeight="Bold" Cursor="Hand" Click="CloseButton_Click"/>
                </Grid>
            </Border>
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" BorderBrush="#33FFFFFF" BorderThickness="0,0,1,0" Background="#151A21">
                    <StackPanel Margin="0,20,0,0">
                        <RadioButton Style="{StaticResource SidebarTabStyle}" Content="🔧" x:Name="TabGeneral" IsChecked="True" Checked="Tab_Checked" Tag="0" ToolTip="General"/>
                        <RadioButton Style="{StaticResource SidebarTabStyle}" Content="⚡" x:Name="TabAdvanced" Checked="Tab_Checked" Tag="1" ToolTip="Advanced"/>
                        <RadioButton Style="{StaticResource SidebarTabStyle}" Content="ℹ️" x:Name="TabAbout" Checked="Tab_Checked" Tag="3" ToolTip="About"/>
                    </StackPanel>
                </Border>
                <Grid Grid.Column="1" Margin="20">
                    <ScrollViewer x:Name="PanelGeneral" Visibility="Visible" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="CUSTOM HOTKEYS" Foreground="#00ADEF" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#2A2F36" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                                <StackPanel>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Toggle Menu" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="HkToggleMenu" Style="{StaticResource HotkeyBoxStyle}" Tag="ToggleMenu" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource ActionButtonStyle}" Click="ClearHotkey_Click" Tag="ToggleMenu"/>
                                    </Grid>
                                    <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Mute Active App" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="HkMuteActive" Style="{StaticResource HotkeyBoxStyle}" Tag="MuteActive" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource ActionButtonStyle}" Click="ClearHotkey_Click" Tag="MuteActive"/>
                                    </Grid>
                                    <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Solo Mode (Mute Others)" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="HkSoloMode" Style="{StaticResource HotkeyBoxStyle}" Tag="SoloMode" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource ActionButtonStyle}" Click="ClearHotkey_Click" Tag="SoloMode"/>
                                    </Grid>
                                    <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Unmute All Apps" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="HkUnmuteAll" Style="{StaticResource HotkeyBoxStyle}" Tag="UnmuteAll" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource ActionButtonStyle}" Click="ClearHotkey_Click" Tag="UnmuteAll"/>
                                    </Grid>
                                    <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="30"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="Panic Reset (50% Volume)" Foreground="White" VerticalAlignment="Center"/>
                                        <TextBox Grid.Column="1" x:Name="HkPanicReset" Style="{StaticResource HotkeyBoxStyle}" Tag="PanicReset" IsReadOnly="True" PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>
                                        <Button Grid.Column="2" Content="✕" Style="{StaticResource ActionButtonStyle}" Click="ClearHotkey_Click" Tag="PanicReset"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                            <TextBlock Text="EXTRA FEATURES" Foreground="#00ADEF" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border Background="#2A2F36" CornerRadius="8" Padding="15">
                                <StackPanel>
                                    <CheckBox x:Name="CbMuteMode" Content="Enable Mute Mode" Foreground="White" Margin="0,0,0,10"/>
                                    <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                                    <CheckBox x:Name="CbSoloMode" Content="Enable Solo Mode" Foreground="White" Margin="0,0,0,10"/>
                                    <Border BorderBrush="#11FFFFFF" BorderThickness="0,0,0,1" Margin="0,0,0,10"/>
                                    <CheckBox x:Name="CbPanicMode" Content="Enable Panic Mode" Foreground="White" Margin="0,0,0,0"/>
                                </StackPanel>
                            </Border>
                            <Button Content="SAVE CHANGES" Background="#00ADEF" Foreground="White" 
                                    Margin="0,20,0,0" Padding="10" FontWeight="Bold"
                                    HorizontalAlignment="Right" Click="SaveButton_Click" Cursor="Hand"/>
                        </StackPanel>
                    </ScrollViewer>
                    <Grid x:Name="PanelAdvanced" Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="DANGER ZONE" Foreground="#FF6B6B" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                            <Border BorderBrush="#FF6B6B" BorderThickness="1" Background="#2A2F36" CornerRadius="8" Padding="15">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="Reset Utility" Foreground="White" FontWeight="Bold"/>
                                        <TextBlock Text="Permanently restore all settings and hotkeys to defaults." Foreground="#AAAAAA" FontSize="11" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button Content="RESET SETTINGS" Background="Transparent" Foreground="#FF6B6B" 
                                            BorderBrush="#FF6B6B" BorderThickness="1" Padding="15,5"
                                            HorizontalAlignment="Right" VerticalAlignment="Center" FontWeight="Bold"
                                            Click="ResetButton_Click" Cursor="Hand"/>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                    <ScrollViewer x:Name="PanelHelp" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
                        <Grid>
                            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top"
                                    Margin="0,0,5,0" Width="30" Height="30"
                                    Style="{StaticResource ActionButtonStyle}" Click="CloseHelp_Click" ToolTip="Back"/>
                            <StackPanel Margin="0,35,0,0">
                                <TextBlock Text="HOW TO USE" Foreground="#00ADEF" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Border Background="#2A2F36" CornerRadius="8" Padding="15" Margin="0,0,0,10">
                                    <TextBlock Text="1. Hold Ctrl and Scroll your mouse wheel while an app is active to change its volume.&#x0a;2. Use the hotkeys configured in the General tab to perform quick actions.&#x0a;3. Press Ctrl + Alt + V to toggle the main mixer UI." 
                                               Foreground="White" TextWrapping="Wrap"/>
                                </Border>
                                <Border Background="#2A2F36" CornerRadius="8" Padding="15" Height="150">
                                    <TextBlock Text="[ Pictorial Views / Diagrams will go here ]" Foreground="#555555" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </ScrollViewer>
                    <Grid x:Name="PanelAbout" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="Volume Mixer Pro" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="Version 2.0" Foreground="#00ADEF" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,20"/>
                            <TextBlock Text="Designed &amp; Developed for premium audio control." Foreground="#AAAAAA" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
